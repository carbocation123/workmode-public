{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "react": ["../frontend/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../frontend/node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["../frontend/node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "react-dom": ["../frontend/node_modules/@types/react-dom/index.d.ts"],
      "react-dom/client": ["../frontend/node_modules/@types/react-dom/client.d.ts"],
      "react-markdown": ["../frontend/node_modules/react-markdown/index.d.ts"],
      "remark-gfm": ["../frontend/node_modules/remark-gfm/index.d.ts"],
      "vitest": ["../frontend/node_modules/vitest/dist/index.d.ts"]
    },
    "typeRoots": ["../frontend/node_modules/@types"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src"]
}
