  "decoration": { "preset": "retro", "density": 0.36 },
  "assets": [
    { "id": "pixel-proportional", "path": "fonts/pixel-proportional.woff2", "kind": "font" },
    { "id": "pixel-mono", "path": "fonts/pixel-mono.woff2", "kind": "font" }
  ]
