    "accentAlt": "#ff4fa3",
    "background": "#0b0711",
    "surface": "#160d20",
    "surfaceRaised": "#2d193a",
    "text": "#f6eaff",
    "textMuted": "#b59bc3",
    "border": "#5b356d",
    "success": "#42eadc",
    "warning": "#ffd166",
    "danger": "#ff6d78",
