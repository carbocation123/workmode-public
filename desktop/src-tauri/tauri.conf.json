{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workmode Public",
  "version": "0.8.9",
  "identifier": "com.workmode.public",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Workmode Public",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' asset: http://asset.localhost http://127.0.0.1:* data: blob:; font-src 'self' data: blob:; frame-src 'self' http://127.0.0.1:* blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "Workmode Public",
    "category": "Productivity",
    "shortDescription": "Local-first research work assistant",
    "longDescription": "A local-first research work assistant with project file tools, work memory, context compression and a desktop updater.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/": ""
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg1MTc1Nzg0MTVENjEzRTUKUldUbEU5WVZoRmNYaGJ6QUlTSEl0QW90Z0ptQ3VNMWZNelRaT0Q3RHVoV29kUXp1VCtUYTBxNEkK",
      "endpoints": [
        "https://github.com/carbocation123/workmode-public/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
