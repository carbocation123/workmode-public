# Workmode Public local configuration
#
# Copy this file to .env or set these variables in your shell.

# Local server. Keep 127.0.0.1 for personal desktop distribution.
WORKMODE_HOST=127.0.0.1
WORKMODE_PORT=8765

# Optional API token. If set, enter the same value in Settings -> Local access token.
# WORKMODE_PUBLIC_TOKEN=change-me-local-token

# Direct backend default: %APPDATA%\WorkmodePublic on Windows.
# The installed desktop app overrides this to %LOCALAPPDATA%\WorkmodePublic\data.
# WORKMODE_PUBLIC_DATA_DIR=C:\Users\you\AppData\Roaming\WorkmodePublic

# Optional root for app-managed literature projects. Windows prefers D:\workmode
# when D: exists and otherwise falls back to the current user's ~/workmode.
# WORKMODE_MANAGED_PROJECTS_DIR=D:\workmode

# OpenAI-compatible model endpoint.
WORKMODE_MODEL_BASE_URL=https://api.deepseek.com/v1
WORKMODE_MODEL_NAME=deepseek-v4-pro
WORKMODE_MODEL_API_KEY=

# Approximate prompt budget. Fixed context and tool schemas are deducted first;
# recent legal history is then selected dynamically within the remaining budget.
WORKMODE_CONTEXT_BUDGET_TOKENS=700000

# Model request setup timeout in seconds. Streaming reads may remain open afterward.
WORKMODE_REQUEST_TIMEOUT_SECONDS=120

# Optional literature pipeline. Keep the token in this local environment file;
# never place it in a project, note, prompt, log, or Git commit.
# MinerU is optional. Configure it in the application settings for higher-fidelity
# tables, formulas and multi-column layouts. Text-layer PDFs remain AI-readable.
# WORKMODE_MINERU_API_KEY=
# WORKMODE_MINERU_MODEL_VERSION=pipeline
# WORKMODE_MINERU_LANGUAGE=en
# WORKMODE_MINERU_TIMEOUT_SECONDS=180
